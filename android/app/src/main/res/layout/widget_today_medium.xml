<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_medium_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:id="@+id/widget_medium_card"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center_vertical"
        android:padding="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="30dp">

        <!-- 日期 -->
        <TextView
            android:id="@+id/widget_medium_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_alignParentTop="true"
            android:text="4月1日 周三"
            android:textColor="#64748B"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- 状态标签 -->
        <TextView
            android:id="@+id/widget_medium_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_alignParentTop="true"
            android:background="@drawable/widget_status_chip"
            android:paddingLeft="10dp"
            android:paddingTop="3dp"
            android:paddingRight="10dp"
            android:paddingBottom="3dp"
            android:text="上课中"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- 课程名 -->
        <TextView
            android:id="@+id/widget_medium_course_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_below="@id/widget_medium_date"
            android:layout_marginTop="10dp"
            android:maxLines="1"
            android:text="高等数学"
            android:textColor="#0F172A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- 节次（靠左） -->
        <TextView
            android:id="@+id/widget_medium_section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_below="@id/widget_medium_course_name"
            android:layout_marginTop="6dp"
            android:maxLines="1"
            android:text="第 1-2 节"
            android:textColor="#64748B"
            android:textSize="12sp" />

        <!-- 时间（靠右） -->
        <TextView
            android:id="@+id/widget_medium_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_below="@id/widget_medium_course_name"
            android:layout_marginTop="6dp"
            android:maxLines="1"
            android:text="08:30 - 10:00"
            android:textColor="#0F172A"
            android:textSize="12sp"
            android:textStyle="bold" />

        <!-- 地点（靠左） -->
        <TextView
            android:id="@+id/widget_medium_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentLeft="true"
            android:layout_below="@id/widget_medium_section"
            android:layout_marginTop="3dp"
            android:maxLines="1"
            android:text="A301教室"
            android:textColor="#64748B"
            android:textSize="11sp"
            android:textStyle="bold" />

        <!-- 进度条（吸底） -->
        <ProgressBar
            android:id="@+id/widget_medium_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentLeft="true"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress_bar" />

    </RelativeLayout>

</FrameLayout>
