<?xml version="1.0" encoding="utf-8"?>
<!-- 
    通知展开状态布局
    参考 mikcb 设计，显示更多课程信息
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- 当前课程区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 图标 -->
        <ImageView
            android:id="@+id/expanded_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/widget_status_active"
            android:background="@drawable/notification_icon_bg"
            android:padding="10dp"/>

        <!-- 当前课程信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/expanded_current_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="当前课程"
                android:textSize="11sp"
                android:textColor="#1D9BF0"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/expanded_course_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="高等数学"
                android:textSize="16sp"
                android:textColor="#1E293B"
                android:textStyle="bold"
                android:maxLines="1"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/expanded_course_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="A301 · 08:30-10:05"
                android:textSize="13sp"
                android:textColor="#64748B"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- 进度 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/expanded_progress_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="65%"
                android:textSize="20sp"
                android:textColor="#1D9BF0"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/expanded_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="剩余25分钟"
                android:textSize="11sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 进度条 -->
    <ProgressBar
        android:id="@+id/expanded_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:progressDrawable="@drawable/widget_progress_light"
        android:progress="65"
        android:max="100"/>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E2E8F0"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- 下一节课 -->
    <LinearLayout
        android:id="@+id/next_course_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="下一节"
            android:textSize="11sp"
            android:textColor="#94A3B8"
            android:background="@drawable/widget_status_bg_light"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"/>

        <TextView
            android:id="@+id/next_course_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="大学英语"
            android:textSize="13sp"
            android:textColor="#1E293B"
            android:maxLines="1"
            android:layout_marginStart="8dp"/>

        <TextView
            android:id="@+id/next_course_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10:25"
            android:textSize="12sp"
            android:textColor="#64748B"/>
    </LinearLayout>

</LinearLayout>