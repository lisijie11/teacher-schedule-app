<?xml version="1.0" encoding="utf-8"?>
<!--
  桌面小组件布局 v3
  修复要点：
  1. 去掉 layout_weight 弹性布局 → RemoteViews 不支持，会导致部分 ROM 崩溃
  2. 改用 RelativeLayout + alignParentXxx 做定位
  3. 所有颜色改为不透明（RRGGBB），避免带 alpha 颜色兼容问题
  4. 保留 widget_root id 用于 PendingIntent 绑定
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- 顶部：日期 + 模式标签 -->
    <LinearLayout
        android:id="@+id/top_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="3月30日 周一"
            android:textSize="11sp"
            android:textColor="#A0B4D0"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/widget_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="工作日"
            android:textSize="10sp"
            android:textColor="#8FA8FF"
            android:textStyle="bold"
            android:maxLines="1"/>

    </LinearLayout>

    <!-- 底部：状态 + 时间大字 -->
    <LinearLayout
        android:id="@+id/bottom_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="下节课 · 18分钟后"
            android:textSize="12sp"
            android:textColor="#7A9EC8"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/widget_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10:25"
            android:textSize="38sp"
            android:textColor="#E8EEFF"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:maxLines="1"/>

    </LinearLayout>

</RelativeLayout>
