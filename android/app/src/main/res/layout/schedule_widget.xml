<?xml version="1.0" encoding="utf-8"?>
<!--
  桌面小组件布局 v4 升级版
  设计升级要点：
  1. 多层分组显示（日期 + 模式 + 状态 + 时间）
  2. 左侧装饰条（视觉焦点）+ 右侧信息对齐
  3. 增强排版层级（大标题时间 + 次要文字）
  4. 优化色彩对比和可读性
  5. 改进卡片内部布局，更符合 Material Design 3
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- ════════════════════════════════════
         顶部行：日期 + 模式标签
         ════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/top_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="3月30日 周一"
            android:textSize="11sp"
            android:textColor="#8B94AA"
            android:maxLines="1"
            android:ellipsize="end"
            android:letterSpacing="0.02"/>

        <TextView
            android:id="@+id/widget_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg_v2"
            android:paddingLeft="11dp"
            android:paddingRight="11dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="工作日"
            android:textSize="10sp"
            android:textColor="#9BB1FF"
            android:textStyle="bold"
            android:maxLines="1"/>

    </LinearLayout>

    <!-- ════════════════════════════════════
         左侧装饰条 (沿右边界)
         ════════════════════════════════════ -->
    <View
        android:id="@+id/decorator_bar"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:layout_alignParentRight="true"
        android:layout_below="@id/top_row"
        android:background="#6C63FF"
        android:layout_marginRight="0dp"
        android:alpha="0.4"/>

    <!-- ════════════════════════════════════
         底部行：主时间 + 状态信息
         ════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottom_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:layout_marginRight="8dp">

        <!-- 状态标签 -->
        <TextView
            android:id="@+id/widget_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="下节课 · 18分钟后"
            android:textSize="11sp"
            android:textColor="#6B8BC7"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"
            android:letterSpacing="-0.01"/>

        <!-- 大时间 -->
        <TextView
            android:id="@+id/widget_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10:25"
            android:textSize="42sp"
            android:textColor="#E8EEFF"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:lineHeight="48sp"
            android:letterSpacing="-0.02"/>

    </LinearLayout>

</RelativeLayout>
