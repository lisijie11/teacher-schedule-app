<?xml version="1.0" encoding="utf-8"?>
<!--
  小部件背景：小号 (2x1)
  小米澎湃OS3风格：深色毛玻璃 + 紫色渐变
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#1E1E2E"
        android:centerColor="#252536"
        android:endColor="#1A1A28"/>
    <corners android:radius="16dp"/>
    <stroke android:width="0.5dp" android:color="#3F3F5A"/>
</shape>
