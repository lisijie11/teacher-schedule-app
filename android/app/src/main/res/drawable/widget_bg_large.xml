<?xml version="1.0" encoding="utf-8"?>
<!--
  小部件背景：大号 (4x4)
  小米澎湃OS3风格：深色卡片 + 圆角 + 微妙边框
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="135"
        android:startColor="#1A1A2E"
        android:centerColor="#1E1E30"
        android:endColor="#16162A"/>
    <corners android:radius="20dp"/>
    <stroke android:width="0.5dp" android:color="#2D2D45"/>
</shape>
