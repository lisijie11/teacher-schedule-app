<?xml version="1.0" encoding="utf-8"?>
<!--
  小组件背景 v4 升级版 - 多层渐变效果
  设计要点：
  1. 主背景：深海军蓝，略带紫调
  2. 内层微渐变：增加深度感
  3. 外层边框：半透明白，保持高级感
  4. 圆角：20dp 保持圆润
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 基础层：纯色背景 -->
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#181A30"/>
            <corners android:radius="20dp"/>
        </shape>
    </item>

    <!-- 中层：微弱渐变（增加深度） -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#1E1F3A"
                android:endColor="#161730"
                android:centerColor="#1A1B35"/>
            <corners android:radius="19dp"/>
        </shape>
    </item>

    <!-- 顶层：边框 + 内发光效果 -->
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="20dp"/>
            <stroke
                android:width="1dp"
                android:color="#3A3C6A"/>
        </shape>
    </item>

    <!-- 外边框：淡紫蓝调，增强视觉 -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="19dp"/>
            <stroke
                android:width="0.5dp"
                android:color="#6C63FF"/>
        </shape>
    </item>
</layer-list>
