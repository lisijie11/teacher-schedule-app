<?xml version="1.0" encoding="utf-8"?>
<!--
  chip_bg_v2：升级版标签背景
  设计要点：
  1. 内层：暗紫色，融入背景
  2. 外边框：靛蓝色边框，突出主色
  3. 圆角：14dp（比之前增加）
  4. 渐变：细微渐变增加深度
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 基础色 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="180"
                android:startColor="#2A2C4A"
                android:endColor="#262844"
                android:centerColor="#282A46"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>

    <!-- 边框 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="14dp"/>
            <stroke
                android:width="1.2dp"
                android:color="#6C63FF"/>
        </shape>
    </item>
</layer-list>