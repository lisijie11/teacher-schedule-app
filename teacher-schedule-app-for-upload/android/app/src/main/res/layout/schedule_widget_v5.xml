<?xml version="1.0" encoding="utf-8"?>
<!--
  桌面小组件布局 v5 增强版
  设计升级要点：
  1. 支持显示多个课程（最多3个）
  2. 添加个性化设置显示（用户信息、学院等）
  3. 改进视觉层级，更清晰的结构
  4. 添加交互性指示（点击区域提示）
  5. 增强动画效果支持
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- ════════════════════════════════════
         顶部行：个性化信息（用户+学院）
         ════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/user_info_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <!-- 用户头像/图标容器 -->
        <LinearLayout
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/chip_bg_v2"
            android:gravity="center"
            android:layout_marginRight="10dp">
            
            <TextView
                android:id="@+id/user_avatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="李"
                android:textSize="14sp"
                android:textColor="#9BB1FF"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- 用户信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:id="@+id/user_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="李老师"
                android:textSize="12sp"
                android:textColor="#E8EEFF"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"/>
                
            <TextView
                android:id="@+id/faculty_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数字媒体与设计学院"
                android:textSize="10sp"
                android:textColor="#8B94AA"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- 日期 -->
        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3月30日"
            android:textSize="11sp"
            android:textColor="#8B94AA"
            android:maxLines="1"/>
    </LinearLayout>

    <!-- ════════════════════════════════════
         分隔线
         ════════════════════════════════════ -->
    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_below="@id/user_info_row"
        android:background="#2A3456"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="10dp"/>

    <!-- ════════════════════════════════════
         课程列表容器（可滚动）
         ════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/courses_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/divider"
        android:orientation="vertical"
        android:layout_marginBottom="10dp">

        <!-- 课程项1 -->
        <LinearLayout
            android:id="@+id/course_item_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="visible">

            <!-- 课程时间 -->
            <TextView
                android:id="@+id/course_time_1"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="09:00"
                android:textSize="14sp"
                android:textColor="#F3F6FF"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:layout_marginRight="12dp"/>

            <!-- 课程信息 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/course_name_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数字合成技术"
                    android:textSize="13sp"
                    android:textColor="#E8EEFF"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">
                    
                    <TextView
                        android:id="@+id/course_location_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="A-201"
                        android:textSize="10sp"
                        android:textColor="#8B94AA"
                        android:maxLines="1"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="·"
                        android:textSize="10sp"
                        android:textColor="#8B94AA"
                        android:layout_marginLeft="6dp"
                        android:layout_marginRight="6dp"/>
                        
                    <TextView
                        android:id="@+id/course_class_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="软工2101班"
                        android:textSize="10sp"
                        android:textColor="#8B94AA"
                        android:maxLines="1"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 状态指示器 -->
            <View
                android:id="@+id/course_status_1"
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="#4CAF50"
                android:layout_marginLeft="8dp"/>
        </LinearLayout>

        <!-- 课程项2 -->
        <LinearLayout
            android:id="@+id/course_item_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp"
            android:visibility="gone">

            <!-- 课程时间 -->
            <TextView
                android:id="@+id/course_time_2"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="10:40"
                android:textSize="14sp"
                android:textColor="#F3F6FF"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:layout_marginRight="12dp"/>

            <!-- 课程信息 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/course_name_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="数字调色"
                    android:textSize="13sp"
                    android:textColor="#E8EEFF"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">
                    
                    <TextView
                        android:id="@+id/course_location_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="B-105"
                        android:textSize="10sp"
                        android:textColor="#8B94AA"
                        android:maxLines="1"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="·"
                        android:textSize="10sp"
                        android:textColor="#8B94AA"
                        android:layout_marginLeft="6dp"
                        android:layout_marginRight="6dp"/>
                        
                    <TextView
                        android:id="@+id/course_class_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="数媒2103班"
                        android:textSize="10sp"
                        android:textColor="#8B94AA"
                        android:maxLines="1"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 状态指示器 -->
            <View
                android:id="@+id/course_status_2"
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="#FF9800"
                android:layout_marginLeft="8dp"/>
        </LinearLayout>

        <!-- 课程项3 -->
        <LinearLayout
            android:id="@+id/course_item_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <!-- 课程时间 -->
            <TextView
                android:id="@+id/course_time_3"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="14:00"
                android:textSize="14sp"
                android:textColor="#F3F6FF"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:layout_marginRight="12dp"/>

            <!-- 课程信息 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                
                <TextView
                    android:id="@+id/course_name_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="影视后期合成"
                    android:textSize="13sp"
                    android:textColor="#E8EEFF"
                    android:maxLines="1"
                    android:ellipsize="end"/>
                    
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="2dp">
                    
                    <TextView
                        android:id="@+id/course_location_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="C-308"
                        android:textSize="10sp"
                        android:textColor="#8B94AA"
                        android:maxLines="1"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="·"
                        android:textSize="10sp"
                        android:textColor="#8B94AA"
                        android:layout_marginLeft="6dp"
                        android:layout_marginRight="6dp"/>
                        
                    <TextView
                        android:id="@+id/course_class_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="动画2102班"
                        android:textSize="10sp"
 android:textColor="#8B94AA"
                        android:maxLines="1"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 状态指示器 -->
            <View
                android:id="@+id/course_status_3"
                android:layout_width="4dp"
                android:layout_height="24dp"
                android:background="#2196F3"
                android:layout_marginLeft="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ════════════════════════════════════
         底部行：模式标签 + 状态摘要
         ════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/bottom_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- 模式标签 -->
        <TextView
            android:id="@+id/widget_mode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/chip_bg_v2"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="工作日·佛山大部"
            android:textSize="10sp"
            android:textColor="#9BB1FF"
            android:textStyle="bold"
            android:maxLines="1"/>

        <!-- 状态摘要 -->
        <TextView
            android:id="@+id/widget_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="今天有3节课，18分钟后开始"
            android:textSize="11sp"
            android:textColor="#6B8BC7"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="right"
            android:layout_marginLeft="10dp"/>
    </LinearLayout>

</RelativeLayout>